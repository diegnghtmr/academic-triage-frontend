{
  "name": "academic-triage-spa",
  "version": "1.0.0",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22.12.0 <23.0.0"
  },
  "scripts": {
    "dev": "ng serve academic-triage-spa",
    "build": "ng build academic-triage-spa",
    "start": "ng serve academic-triage-spa",
    "start:angular": "ng serve academic-triage-spa",
    "check": "tsc -p tsconfig.app.json --noEmit",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "ng": "ng"
  },
  "dependencies": {
    "@angular/common": "^20.3.0",
    "@angular/compiler": "^20.3.0",
    "@angular/core": "^20.3.0",
    "@angular/forms": "^20.3.18",
    "@angular/platform-browser": "^20.3.0",
    "@angular/router": "^20.3.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular/build": "^20.3.23",
    "@angular/cli": "^20.3.23",
    "@angular/compiler-cli": "^20.3.0",
    "@eslint/js": "^9.37.0",
    "@playwright/test": "^1.56.0",
    "@types/node": "20.19.27",
    "@vitest/coverage-v8": "^3.2.4",
    "angular-eslint": "^20.4.0",
    "esbuild": "^0.25.0",
    "eslint": "^9.37.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.6.2",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.46.1",
    "vitest": "^3.2.4"
  }
}
